{
	"info": {
		"name": "BankLiteAPI",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5028"
		},
		{
			"key": "token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"fullName\": \"Test User\",\n\t\"email\": \"user@example.com\",\n\t\"password\": \"Password123\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": "{{baseUrl}}/api/auth/register"
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"email\": \"test@banklite.com\",\n\t\"password\": \"Password123\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": "{{baseUrl}}/api/auth/login"
					}
				}
			]
		},
		{
			"name": "Accounts",
			"item": [
				{
					"name": "Create Account",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"type\": 0\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": "{{baseUrl}}/api/account/create"
					}
				},
				{
					"name": "Get Accounts",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": "{{baseUrl}}/api/account"
					}
				}
			]
		},
		{
			"name": "Transactions",
			"item": [
				{
					"name": "Deposit",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"accountId\": \"REPLACE_WITH_ACCOUNT_ID\",\n\t\"amount\": 500\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": "{{baseUrl}}/api/transaction/deposit"
					}
				},
				{
					"name": "Withdraw",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"accountId\": \"REPLACE_WITH_ACCOUNT_ID\",\n\t\"amount\": 100\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": "{{baseUrl}}/api/transaction/withdraw"
					}
				},
				{
					"name": "Transfer",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"fromAccountId\": \"REPLACE_WITH_FROM_ACCOUNT_ID\",\n\t\"toAccountId\": \"REPLACE_WITH_TO_ACCOUNT_ID\",\n\t\"amount\": 200\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": "{{baseUrl}}/api/transaction/transfer"
					}
				},
				{
					"name": "Get Transaction History",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {
							"raw": "{{baseUrl}}/api/transaction/REPLACE_WITH_ACCOUNT_ID?page=1&pageSize=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "transaction", "REPLACE_WITH_ACCOUNT_ID"],
							"query": [
								{"key": "page", "value": "1"},
								{"key": "pageSize", "value": "10"}
							]
						}
					}
				}
			]
		},
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/health"
					}
				}
			]
		}
	]
}

{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=BankLiteDB;Trusted_Connection=True;"
  },
  "JwtSettings": {
    "Secret": "YOUR_SECRET_KEY_MIN_32_CHARACTERS",
    "Issuer": "BankLiteAPI",
    "Audience": "BankLiteClient",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
